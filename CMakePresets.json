{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "PICO_SDK_PATH": "${sourceDir}/../pico-sdk",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../pico-sdk/cmake/preload/toolchains/pico_arm_cortex_m0plus_gcc.cmake",
        "PICO_TOOLCHAIN_PATH": "/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/bin"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "release"
    }
  ]
}
