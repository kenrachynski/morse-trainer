CompileFlags:
  CompilationDatabase: build/debug
  Add:
    # ARM GCC 15.2.1 system includes — needed because Apple clangd won't execute
    # --query-driver to discover these automatically.
    - -isystem/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include/c++/15.2.1
    - -isystem/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include/c++/15.2.1/arm-none-eabi
    - -isystem/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include/c++/15.2.1/backward
    - -isystem/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/lib/gcc/arm-none-eabi/15.2.1/include
    - -isystem/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/lib/gcc/arm-none-eabi/15.2.1/include-fixed
    - -isystem/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include

Diagnostics:
  UnusedIncludes: None
